# AWS Region
aws_region = "us-east-1"

# Environment
environment = "prod"

# Network Configuration
vpc_cidr = "10.0.0.0/16"

availability_zones = ["us-east-1a", "us-east-1b"]

public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]
private_app_cidrs  = ["10.0.11.0/24", "10.0.12.0/24"]
private_db_cidrs   = ["10.0.21.0/24", "10.0.22.0/24"]

# Instance Types
app_instance_type = "t2.micro"
web_instance_type = "t2.micro"

# Database Credentials
db_username = "admin"
db_password = "ChangeMe123!"  # Change this to a secure password

# S3 Bucket for Application Code
s3_bucket_name = "my-app-code-bucket"  # Must be globally unique
